# AKF runtime mode
AKF_ENV=dev

# Required when AKF_ENV=prod
AKF_API_KEY=change-me

# Runtime hardening
AKF_CORS_ORIGINS=http://localhost:3000
AKF_MAX_REQUEST_BYTES=1048576
AKF_MAX_CONCURRENCY=8

# Rate limits
AKF_RATE_LIMIT_DEFAULT=60/minute
AKF_RATE_LIMIT_GENERATE=10/minute
AKF_RATE_LIMIT_VALIDATE=30/minute
AKF_RATE_LIMIT_BATCH=3/minute
AKF_RATE_LIMIT_ASK=10/minute

# Logging
AKF_LOG_JSON=true
AKF_LOG_LEVEL=INFO

# Paths
AKF_OUTPUT_DIR=./output
AKF_TELEMETRY_PATH=telemetry/events.jsonl
